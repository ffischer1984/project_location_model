        "kfwProjectNoINPRO": {
            "description": "Every project location in the FC Geodata Model must be assigned to its respective KfW project number, which is provided by KfW.",
            "type": "string"
        },
        "location_activity_status": {
            "description": "The location activity status according to the IATI standard. If you are unaware of the current status please choose 'NA'.",
            "enum": [
                "NA",
                "Pipeline/identification",
                "Implementation",
                "Finalisation",
                "Closed",
                "Cancelled",
                "Suspended",
                "Other"
            ],
            "type": "string"
        },
        "location_name": {
            "attribute_name": "Location name",
            "attribute_code": "location_name",
            "description": "Unique name of the project site and its (main) activity incl local MIS-/GIS-ID, if availabe. This will be used as reference for line and polygon data.",
            "type": "string"
        },
        "plannedOrActualEndDate": {
            "description": "Approximate planned or actual end date of activities on the ground.",
            "format": "date",
            "type": "string"
        },
        "plannedOrActualStartDate": {
            "description": "Approximate planned or actual start date of implementation of activities on the ground.",
            "format": "date",
            "type": "string"
        },
        "primaryKey": {
            "description": "This is only required if you provide additional geolocation information in another KML file.",
            "type": "string"
        },
        "project_acronym": {
            "description": "Enter the acronym used for the name/title of the project (e.g. HREII) to be visible on your map. If the project has multiple phases, please add the number of the phase belonging to the before-stated KfW Project-No.",
            "type": "string"
        },
        "projectSpecificLocationIdentifier": {
            "description": "If the location or activity has a project-specific identifier, it can be entered here.",
            "type": "string"
        },
        "publishing_restrictions": {
            "description": "Indicates if the exact location is collected in fragile areas (e.g. of severe civil conflict or war) and should therefore be omitted from publicly available reports.",
            "enum": [
                "yes ",
                "no"
            ],
            "type": "string"
        },
        "related_community": {
            "description": "Enter a community, village, hamlet or neighbourhood name that relates to this location, this can serve for manually add smaller administrative unit names that are not in global databases.",
            "type": "string"
        },
        "uniqueId": {
            "description": "For new locations, this column is empty. For updates, your KfW counterpart will provide you with a list of unique_id numbers in this file to ensure that updated location IDs match with the former ones.",
            "type": "string"
        },
        "latitude": {
            "attribute_name": "Latitude",
            "attribute_code": "latitude",
            "description": "Enter the Latitude (at least 5 digits!) measured with a GPS device (or centroid or admin unit polygon for approximate locations). Use WGS 84 as the Coordinate Reference System (EPSG:4326).",
            "type": "number",
            "minimum": -90,
            "maximum": 90
        },
        "longitude": {
            "attribute_name": "Longitude",
            "attribute_code": "longitude",
            "description": "Enter the Longitude (at least 5 digits!) measured with a GPS device (or centroid or admin unit polygon for approximate locations). Use WGS 84 as the Coordinate Reference System (EPSG:4326).",
            "type": "number",
            "minimum": -180,
            "maximum": 180
        }
    },
    "required": [
        "f_id",
        "scheme_version",
        "donor_project_no",
        "project_acronym",
        "data_provider",
        "publishing_restrictions",
        "date_of_data_collection",
        "related_community",
        "location_name",
        "location_activity_status",
        "activity_start_date",
        "activity_end_date",
        "activity_description",
        "location_type_name",
        "geographic_exactness"
    ],
    "title": "Project Location Model",
    "type": "object"
}